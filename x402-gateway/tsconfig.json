{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "../mcp-server/db.ts",
    "../mcp-server/analytics.ts",
    "../lib/analytics/engine.ts",
    "../lib/analytics/premium.ts",
    "../lib/supabase/types.ts"
  ]
}
